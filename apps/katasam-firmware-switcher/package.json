{
  "name": "katasam-firmware-switcher",
  "version": "1.1.0",
  "description": "KATASAM Switcher - Switch between Classic and Santroller firmware",
  "main": "main.js",
  "scripts": {
    "postinstall": "electron-rebuild",
    "start": "electron .",
    "package": "npx -y node@20 ./node_modules/electron-builder/cli.js --dir",
    "make": "npx -y node@20 ./node_modules/electron-builder/cli.js",
    "make:mac": "npm run make -- --mac",
    "make:win": "npm run make -- --win --x64",
    "make:linux": "npm run make -- --linux",
    "build": "npm run build:mac",
    "build:mac": "npm run make:mac",
    "build:mac:arm64": "npm run make:mac -- --arm64",
    "build:mac:x64": "npm run make:mac -- --x64",
    "build:mac:zip": "npm run make -- --mac zip",
    "build:win": "npm run make:win",
    "build:linux": "npm run make:linux",
    "build:all": "npm run make -- --mac --win --linux"
  },
  "author": "Martyn Watts",
  "license": "MIT",
  "dependencies": {
    "node-hid": "^2.1.2",
    "serialport": "^12.0.0",
    "usb": "^2.17.0"
  },
  "devDependencies": {
    "electron": "^37.10.3",
    "electron-builder": "^24.9.1",
    "@electron/rebuild": "^4.0.4"
  },
  "build": {
    "appId": "com.katasam.firmwareswitcher",
    "productName": "KATASAM Switcher",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "preload.js",
      "renderer.js",
      "renderer-minimal.js",
      "index.html",
      "index-minimal.html",
      "styles.css",
      "electropick-logo.png",
      "node_modules/**/*"
    ],
    "mac": {
      "category": "public.app-category.utilities",
      "target": [
        "dmg",
        "zip"
      ],
      "icon": "assets/icon.icns",
      "identity": null,
      "signIgnore": ".*"
    },
    "dmg": {
      "contents": [
        {
          "x": 130,
          "y": 220
        },
        {
          "x": 410,
          "y": 220,
          "type": "link",
          "path": "/Applications"
        }
      ],
      "title": "KATASAM Switcher",
      "background": null,
      "window": {
        "width": 540,
        "height": 380
      }
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "assets/icon.ico",
      "requestedExecutionLevel": "asInvoker"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "KATASAM Switcher",
      "installerIcon": "assets/icon.ico",
      "uninstallerIcon": "assets/icon.ico",
      "installerHeaderIcon": "assets/icon.ico",
      "license": "LICENSE.txt"
    },
    "portable": {
      "artifactName": "KATASAM-Switcher-Portable-${version}.exe"
    },
    "linux": {
      "target": [
        "AppImage",
        "deb",
        "rpm"
      ],
      "category": "Utility",
      "icon": "assets/icon.png",
      "desktop": {
        "Name": "KATASAM Switcher",
        "Comment": "Flash firmware to RP2040 devices",
        "Categories": "Utility;System;"
      }
    },
    "appImage": {
      "artifactName": "KATASAM-Switcher-${version}.AppImage"
    }
  }
}
